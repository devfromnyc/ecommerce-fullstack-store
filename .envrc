# direnv configuration for local/development secrets.
# Run `direnv allow` after creating or editing this file.

# Load standard env files if present.
dotenv_if_exists .env
dotenv_if_exists .env.local
dotenv_if_exists .env.development

# Load machine-only secrets (kept out of git).
source_env_if_exists .envrc.local

# Safe defaults for local startup.
export NODE_ENV="${NODE_ENV:-development}"
export NEXT_PUBLIC_BASE_URL="${NEXT_PUBLIC_BASE_URL:-http://localhost:3000}"

# Optional: export CLI/VPN flags used by your setup scripts.
# export USE_CORP_VPN=true
